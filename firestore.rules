rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny for all collections
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner') ||
        (request.auth.token.email == "p.e.muryadi@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidEmail(email) {
      return email is string && email.matches('^[^@]+@[^@]+\\.[^@]+$');
    }

    // ===============================================================
    // Entity Validators
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 128 &&
             isValidEmail(data.email) &&
             data.role in ['owner', 'premium', 'guest', 'titan', 'supreme', 'ultimate', 'essential'] &&
             (!('tier' in data) || data.tier in ['Free', 'Essential', 'Premium', 'Ultimate', 'SUPREME', 'Titan', 'owner', 'Free']) &&
             (!('tokens' in data) || data.tokens is number) &&
             (!('lastResetDate' in data) || (data.lastResetDate is string && data.lastResetDate.size() < 24)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 128)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 1024)) &&
             (!('nip' in data) || (data.nip is string && data.nip.size() < 64)) &&
             (!('jenjang' in data) || (data.jenjang is string && data.jenjang.size() < 32)) &&
             (!('tahunPelajaran' in data) || (data.tahunPelajaran is string && data.tahunPelajaran.size() < 32)) &&
             (!('namaSekolah' in data) || (data.namaSekolah is string && data.namaSekolah.size() < 128)) &&
             (!('kepalaSekolah' in data) || (data.kepalaSekolah is string && data.kepalaSekolah.size() < 128)) &&
             (!('nipKepalaSekolah' in data) || (data.nipKepalaSekolah is string && data.nipKepalaSekolah.size() < 64)) &&
             (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() < 64));
    }

    function isValidActivityLog(data) {
      return data.keys().hasAll(['msg', 'status', 'color', 'time', 'timestamp']) &&
             data.msg is string && data.msg.size() < 500 &&
             data.status is string && data.status.size() < 50 &&
             data.color is string && data.color.size() < 50 &&
             data.time is string && data.time.size() < 50 &&
             data.timestamp is number;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (
        request.resource.data.role == 'guest' || isAdmin()
      );
      allow update: if (isOwner(userId) && 
                      request.resource.data.uid == resource.data.uid && 
                      request.resource.data.role == resource.data.role &&
                      (!('tier' in request.resource.data) || !('tier' in resource.data) || request.resource.data.tier == resource.data.tier) &&
                      isValidUser(request.resource.data)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /activityLogs/{logId} {
      allow list: if true;
      allow get: if true;
      allow create: if isValidActivityLog(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /system/stats {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if (hasRequiredFields(['favorites']) && 
                      request.resource.data.favorites is number &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favorites']) &&
                      request.resource.data.favorites == resource.data.favorites + 1) || isAdmin();
    }
  }
}
